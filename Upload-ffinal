#!/bin/bash

# PLUG POWER ANALYZER - Upload to GitHub
# Este script sube tu app directamente a GitHub con tus credenciales

GITHUB_USER="raulin2810"
GITHUB_EMAIL="Rhernandez.m@gmx.de"
GITHUB_PASSWORD="Rachelis16101990"
REPO_NAME="plug-power"

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║   PLUG POWER ANALYZER - Subiendo a GitHub                    ║"
