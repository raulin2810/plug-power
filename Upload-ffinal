REPO_DIR="$HOME/Documents/plug-power-upload"
rm -rf "$REPO_DIR"
mkdir -p "$REPO_DIR"
cd "$REPO_DIR" || exit 1

echo "📁 Working directory: $REPO_DIR"
echo ""

# Copiar archivo
echo "📄 Copying app file..."
if [ -f "$HOME/Downloads/plug-power-app/plug-power-iphone.html" ]; then
    cp "$HOME/Downloads/plug-power-app/plug-power-iphone.html" .
    echo "✅ Found in Downloads"
elif [ -f "$HOME/Downloads/plug-power-iphone.html" ]; then
    cp "$HOME/Downloads/plug-power-iphone.html" .
    echo "✅ Found in Downloads (root)"
else
    echo "❌ Could not find plug-power-iphone.html"
    echo "   Expected at: ~/Downloads/plug-power-app/plug-power-iphone.html"
    echo "   Or: ~/Downloads/plug-power-iphone.html"
    exit 1
fi

echo ""

# Crear README
echo "📝 Creating README.md..."
cat > README.md << 'EOF'
# Plug Power Analyzer 📊

Real-time news analyzer for Plug Power stock (NASDAQ: PLUG).

## 🎯 Features

- ✅ Real-time sentiment analysis of news
- ✅ Investment recommendations: BUY / WAIT / SELL
- ✅ Live news feeds
- ✅ iPhone optimized interface
- ✅ Auto-updates every 5 minutes

## 📱 How to Use

Open this link in Safari on your iPhone:

```
https://raulin2810.github.io/plug-power/plug-power-iphone.html
```

## 🚀 What It Does

1. Fetches latest news about Plug Power
2. Analyzes sentiment (positive/negative/neutral)
3. Recommends: BUY if >60% positive, WAIT if 40-60%, SELL if <40%
4. Updates automatically every 5 minutes

## 📊 How Sentiment Works

- **Positive keywords**: surge, gains, growth, partnership, investment, etc.
- **Negative keywords**: plummets, losses, decline, bankruptcy, lawsuit, etc.
- **Neutral**: Other news

