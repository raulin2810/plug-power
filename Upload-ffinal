Created: March 2026
GitHub Pages: https://raulin2810.github.io/plug-power/
EOF

echo "✅ README created"
echo ""

# Git config
echo "⚙️ Configuring Git..."
git config --global user.name "Plug Power Uploader"
git config --global user.email "$GITHUB_EMAIL"
git config --global credential.helper store

echo "✅ Git configured"
echo ""

# Init repo
echo "🔧 Initializing repository..."
git init > /dev/null 2>&1

echo "✅ Repository initialized"
echo ""

# Add files
echo "📦 Adding files..."
git add plug-power-iphone.html README.md > /dev/null 2>&1

echo "✅ Files added"
echo ""

# Commit
echo "💾 Creating commit..."
git commit -m "Initial commit: Plug Power Analyzer - Real-time news analysis" > /dev/null 2>&1

echo "✅ Commit created"
echo ""

# Remote URL
REMOTE_URL="https://${GITHUB_USER}:${GITHUB_PASSWORD}@github.com/${GITHUB_USER}/${REPO_NAME}.git"

# Add remote
echo "🔗 Adding remote origin..."
git remote add origin "$REMOTE_URL" > /dev/null 2>&1

echo "✅ Remote added"
echo ""

# Rename branch
echo "🌿 Setting main branch..."
git branch -M main > /dev/null 2>&1

echo "✅ Branch set to main"
echo ""

# Push
echo "📤 Pushing to GitHub..."
echo "(This may take a few moments...)"
echo ""

if git push -u origin main 2>&1 | grep -q "master\|main"; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║              ✅ SUCCESS! App uploaded to GitHub!             ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    echo "🔗 Repository:"
    echo "   https://github.com/$GITHUB_USER/$REPO_NAME"
    echo ""
    echo "🔧 NEXT STEP - Activate GitHub Pages (takes 2 minutes):"
    echo ""
    echo "1. Go to:"
    echo "   https://github.com/$GITHUB_USER/$REPO_NAME/settings"
    echo ""
    echo "2. Click 'Pages' in left menu"
    echo ""
    echo "3. Under 'Source':"
    echo "   - Branch: main"
    echo "   - Folder: / (root)"
    echo ""
    echo "4. Click 'Save'"
    echo ""
    echo "5. Wait 2 minutes for GitHub to process"
    echo ""
    echo "📱 Then open in Safari on your iPhone:"
    echo "   https://$GITHUB_USER.github.io/$REPO_NAME/plug-power-iphone.html"
    echo ""
    echo "✅ DONE! Your app is live!"
    echo ""
    
    # Cleanup
    # Uncomment if you want to delete the upload directory
    # cd ~
    # rm -rf "$REPO_DIR"
    
    echo "📁 Upload directory: $REPO_DIR"
